<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}La Petite Maison de l'Épouvante{% endblock %}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

  <style>
    :root {
      --blood:   #8b0000;
      --crimson: #cc0000;
      --ember:   #ff4500;
      --dark:    #0a0a0a;
      --surface: #111111;
      --card-bg: #161616;
      --border:  #2a2a2a;
      --text:    #e8e0d5;
      --muted:   #7a7060;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Crimson Text', Georgia, serif;
      background: var(--dark);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── NAVBAR ─────────────────────────────────────── */
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2.5rem;
      background: rgba(8, 8, 8, 0.95);
      border-bottom: 2px solid var(--blood);
      position: sticky;
      top: 0;
      z-index: 200;
      backdrop-filter: blur(8px);
    }

    .navbar-brand {
      font-family: 'Cinzel Decorative', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--crimson);
      text-decoration: none;
      letter-spacing: 1px;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      transition: color 0.3s;
    }
    .navbar-brand:hover { color: #fff; }
    .navbar-brand .skull { font-size: 1.3rem; }

    .navbar-links {
      list-style: none;
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    .navbar-links a {
      color: var(--text);
      text-decoration: none;
      font-family: 'Cinzel Decorative', serif;
      font-size: 0.65rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: color 0.3s;
      opacity: 0.8;
    }
    .navbar-links a:hover { color: var(--crimson); opacity: 1; }

    .navbar-links .btn-nav-login {
      background: var(--blood);
      color: #fff;
      padding: 0.4rem 1.2rem;
      border-radius: 2px;
      border: 1px solid var(--crimson);
      opacity: 1;
      transition: background 0.3s;
    }
    .navbar-links .btn-nav-login:hover { background: var(--crimson); }

    .navbar-links .btn-nav-logout {
      color: var(--muted);
      font-size: 0.65rem;
      letter-spacing: 1px;
      font-family: 'Crimson Text', serif;
      font-style: italic;
      opacity: 0.7;
    }
    .navbar-links .btn-nav-logout:hover { color: var(--crimson); opacity: 1; }

    /* ── FLASH ──────────────────────────────────────── */
    .flash-container { max-width: 900px; margin: 1rem auto 0; padding: 0 2rem; }
    .flash-success {
      background: rgba(76,175,80,0.1); border: 1px solid #4caf50;
      color: #4caf50; padding: 0.8rem 1.2rem; border-radius: 2px;
      font-size: 0.95rem; margin-bottom: 0.5rem;
    }
    .flash-error {
      background: rgba(139,0,0,0.15); border: 1px solid var(--blood);
      color: #ff6b6b; padding: 0.8rem 1.2rem; border-radius: 2px;
      font-size: 0.95rem; margin-bottom: 0.5rem;
    }
    .flash-warning {
      background: rgba(255,152,0,0.1); border: 1px solid #ff9800;
      color: #ff9800; padding: 0.8rem 1.2rem; border-radius: 2px;
      font-size: 0.95rem; margin-bottom: 0.5rem;
    }

    /* ── FOOTER ─────────────────────────────────────── */
    .footer {
      background: #080808;
      border-top: 2px solid var(--blood);
      padding: 3rem 2rem;
      text-align: center;
    }
    .footer-brand {
      font-family: 'Cinzel Decorative', serif;
      font-size: 1rem; color: var(--crimson);
      margin-bottom: 0.8rem; letter-spacing: 1px;
    }
    .footer-cities {
      font-size: 0.85rem; font-style: italic;
      color: var(--muted); margin-bottom: 0.5rem; letter-spacing: 1px;
    }
    .footer-copy { font-size: 0.75rem; color: #444; letter-spacing: 1px; }

    /* ── BOUTONS GLOBAUX ────────────────────────────── */
    .btn-primary {
      background: var(--blood); color: #fff;
      padding: 0.75rem 2rem; border-radius: 2px;
      text-decoration: none; font-family: 'Cinzel Decorative', serif;
      font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;
      border: 1px solid var(--crimson); display: inline-block;
      transition: background 0.3s, box-shadow 0.3s; cursor: pointer;
    }
    .btn-primary:hover { background: var(--crimson); box-shadow: 0 0 20px rgba(200,0,0,0.4); }

    .btn-secondary {
      background: transparent; color: var(--text);
      padding: 0.75rem 2rem; border-radius: 2px;
      text-decoration: none; font-family: 'Cinzel Decorative', serif;
      font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;
      border: 1px solid var(--border); display: inline-block;
      transition: border-color 0.3s, color 0.3s; cursor: pointer;
    }
    .btn-secondary:hover { border-color: var(--crimson); color: var(--crimson); }

    .btn-warning {
      background: transparent; color: #ff9800;
      padding: 0.5rem 1.2rem; border-radius: 2px;
      text-decoration: none; font-size: 0.8rem;
      border: 1px solid #ff9800; display: inline-block;
      transition: background 0.3s; cursor: pointer;
    }
    .btn-warning:hover { background: rgba(255,152,0,0.1); }

    .btn-danger {
      background: transparent; color: #f44336;
      padding: 0.5rem 1.2rem; border-radius: 2px;
      text-decoration: none; font-size: 0.8rem;
      border: 1px solid #f44336; display: inline-block;
      transition: background 0.3s; cursor: pointer;
    }
    .btn-danger:hover { background: rgba(244,67,54,0.1); }

    /* ── STOCK ──────────────────────────────────────── */
    .stock-ok    { color: #4caf50; font-size: 0.85rem; }
    .stock-low   { color: #ff9800; font-size: 0.85rem; }
    .stock-empty { color: #f44336; font-size: 0.85rem; }
  </style>

  {% block stylesheets %}{% endblock %}
</head>
<body>

<nav class="navbar">
  <a href="{{ path('app_home') }}" class="navbar-brand">
    <span class="skull">💀</span> La Petite Maison de l'Épouvante
  </a>
  <ul class="navbar-links">
    <li><a href="{{ path('app_home') }}">Accueil</a></li>
    <li><a href="{{ path('app_product_index') }}">Catalogue</a></li>
    {% if app.user %}
      <li><a href="{{ path('admin') }}">Dashboard</a></li>
      <li>
        <a href="{{ path('app_logout') }}" class="btn-nav-logout">
          👤 {{ app.user.email }} — Déconnexion
        </a>
      </li>
    {% else %}
      <li><a href="{{ path('app_register') }}">Inscription</a></li>
      <li><a href="{{ path('app_login') }}" class="btn-nav-login">Connexion</a></li>
    {% endif %}
  </ul>
</nav>

{% for type, messages in app.flashes %}
  <div class="flash-container">
    {% for message in messages %}
      <div class="flash-{{ type }}">{{ message }}</div>
    {% endfor %}
  </div>
{% endfor %}

{% block body %}{% endblock %}

<footer class="footer">
  <div class="footer-brand">💀 La Petite Maison de l'Épouvante</div>
  <div class="footer-cities">Angoulême · Aix-en-Provence · Lyon · Londres</div>
  <div class="footer-copy">© 2026 — Tous droits réservés</div>
</footer>

{% block javascripts %}{% endblock %}
</body>
</html>
