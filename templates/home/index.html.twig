{% extends 'base.html.twig' %}

{% block title %}La Petite Maison de l'Épouvante{% endblock %}

{% block stylesheets %}
<style>
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  /* ── HERO ───────────────────────────────────────── */
  .hero {
    background: linear-gradient(135deg, #1a0000 0%, #0a0a0a 50%, #1a0000 100%);
    padding: 5rem 2rem;
    text-align: center;
    border-bottom: 1px solid var(--blood);
    position: relative;
    overflow: hidden;
  }
  .hero h1 {
    font-family: 'Cinzel Decorative', serif;
    font-size: 2.8rem;
    color: var(--crimson);
    margin-bottom: 1rem;
    text-shadow: 0 0 30px rgba(200,0,0,0.6);
  }
  .hero p {
    font-size: 1.2rem;
    color: var(--muted);
    margin-bottom: 2rem;
    font-style: italic;
  }

  /* ── SECTIONS PRODUITS ──────────────────────────── */
  .products-section {
    padding: 3rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .products-section h2 {
    font-family: 'Cinzel Decorative', serif;
    font-size: 1.4rem;
    color: var(--crimson);
    margin-bottom: 2rem;
    text-align: center;
    letter-spacing: 2px;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* ── CARTE PRODUIT ──────────────────────────────── */
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.5rem;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  }
  .card:hover {
    transform: translateY(-5px);
    border-color: var(--blood);
    box-shadow: 0 8px 24px rgba(139,0,0,0.2);
  }
  .card-category {
    font-family: 'Cinzel Decorative', serif;
    font-size: 0.6rem;
    text-transform: uppercase;
    color: var(--crimson);
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
  }
  .card-title {
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }
  .card-desc {
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 1rem;
    line-height: 1.6;
    font-style: italic;
  }
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  .card-price {
    font-size: 1.2rem;
    font-weight: bold;
    color: var(--crimson);
    font-family: 'Cinzel Decorative', serif;
  }

  /* ── BADGE RECOMMANDATION ───────────────────────── */
  .section-recommended {
    background: linear-gradient(180deg, #1a0000 0%, transparent 100%);
    border-top: 1px solid var(--blood);
    border-bottom: 1px solid var(--border);
  }
  .badge-reco {
    display: inline-block;
    background: var(--blood);
    color: #fff;
    font-size: 0.6rem;
    font-family: 'Cinzel Decorative', serif;
    letter-spacing: 2px;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }
</style>
{% endblock %}

{% block body %}

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <h1>Le lieu de rêve pour frissonner</h1>
    <p>Figurines, Blu-ray, Fanzines, Jeux — Tout l'univers de l'horreur et du fantastique</p>
    <a href="{{ path('app_product_index') }}" class="btn-primary">Découvrir le catalogue</a>
  </div>
</section>

<!-- RECOMMANDATIONS -->
{% if recommended is not empty %}
<section class="products-section section-recommended">
  <h2>⚰ Recommandations pour vous</h2>
  <div class="products-grid">
    {% for product in recommended %}
    <a href="{{ path('app_product_show', {id: product.id}) }}" class="card-link">
      <div class="card">
        <span class="badge-reco">Recommandé</span>
        <div class="card-category">{{ product.category }}</div>
        <h3 class="card-title">{{ product.name }}</h3>
        <p class="card-desc">{{ product.description }}</p>
        <div class="card-footer">
          <span class="card-price">{{ product.price }} €</span>
          <span class="
            {% if product.stock > 10 %}stock-ok
            {% elseif product.stock > 0 %}stock-low
            {% else %}stock-empty{% endif %}">
            {% if product.stock > 0 %}En stock ({{ product.stock }}){% else %}Rupture{% endif %}
          </span>
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- CATALOGUE COMPLET -->
<section class="products-section">
  <h2>Nos Produits</h2>
  <div class="products-grid">
    {% for product in products %}
    <a href="{{ path('app_product_show', {id: product.id}) }}" class="card-link">
      <div class="card">
        <div class="card-category">{{ product.category }}</div>
        <h3 class="card-title">{{ product.name }}</h3>
        <p class="card-desc">{{ product.description }}</p>
        <div class="card-footer">
          <span class="card-price">{{ product.price }} €</span>
          <span class="
            {% if product.stock > 10 %}stock-ok
            {% elseif product.stock > 0 %}stock-low
            {% else %}stock-empty{% endif %}">
            {% if product.stock > 0 %}En stock ({{ product.stock }}){% else %}Rupture{% endif %}
          </span>
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
</section>

{% endblock %}